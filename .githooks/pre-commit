#!/bin/sh
# regenerate js/version.js from the commit count (counting this commit too)
n=$(($(git rev-list --count HEAD 2>/dev/null || echo 0) + 1))
d=$(date +%Y-%m-%d)
cat > js/version.js <<VER
// generated by .githooks/pre-commit — do not edit by hand
window.UTSIM_VERSION = { build: $n, date: '$d' };
VER
git add js/version.js
